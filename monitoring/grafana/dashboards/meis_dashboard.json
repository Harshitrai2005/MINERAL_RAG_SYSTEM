{
  "uid": "meis-main",
  "title": "Mineral Exploration RAG — System Dashboard",
  "description": "Full observability for the MEIS RAG pipeline",
  "tags": ["meis", "rag", "mineral-exploration"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Total HTTP Requests (per minute)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(meis_http_requests_total[1m]) * 60",
          "legendFormat": "{{method}} {{path}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "HTTP Request Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(meis_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(meis_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(meis_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 3,
      "title": "RAG Queries per Minute (by type)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(meis_rag_queries_total[1m]) * 60",
          "legendFormat": "{{query_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 4,
      "title": "RAG Pipeline Latency p95 (by query type)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(meis_rag_query_duration_seconds_bucket[5m]))",
          "legendFormat": "{{query_type}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 5,
      "title": "Avg Chunks Retrieved per Query",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "rate(meis_rag_chunks_retrieved_sum[5m]) / rate(meis_rag_chunks_retrieved_count[5m])",
          "legendFormat": "{{query_type}} avg chunks",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "RAG Evaluation Scores by Criterion",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(meis_evaluation_scores_sum[10m]) / rate(meis_evaluation_scores_count[10m])",
          "legendFormat": "{{criterion}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Documents Ingested (success vs error)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(meis_ingest_documents_total[5m]) * 60",
          "legendFormat": "{{doc_type}} — {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 8,
      "title": "Vector Store Document Counts",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "meis_vector_store_documents",
          "legendFormat": "{{collection}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" }
    },
    {
      "id": 9,
      "title": "Error Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "rate(meis_errors_total[1m]) * 60",
          "legendFormat": "{{endpoint}} — {{error_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 10,
      "title": "Ingestion Duration p95 (by doc type)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(meis_ingest_duration_seconds_bucket[10m]))",
          "legendFormat": "{{doc_type}} p95",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto" }
    }
  ]
}

# ── MEIS Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── REQUIRED ───────────────────────────────────────────────────────────────

# Your Groq API key (free tier, no credit card needed)
# Get one at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Backend API key — used by the frontend and seed script to authenticate uploads.
# Set this to any strong random string (e.g. `openssl rand -hex 32`)
API_KEY=change_me_to_a_strong_random_secret

# ── OPTIONAL — defaults work for local development ──────────────────────────

# LLM provider: "groq" (default, free) or "openai"
LLM_PROVIDER=groq

# OpenAI fallback — only needed if LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here

# Vector backend: "lancedb" (local, default) or "qdrant" (cloud, for Render)
VECTOR_BACKEND=lancedb

# Qdrant Cloud — only needed if VECTOR_BACKEND=qdrant
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key

# Re-ranker: "cross_encoder" (best quality) or "keyword" (fast fallback)
RERANKER=cross_encoder

# CORS — set to your frontend domain in production (e.g. https://meis.onrender.com)
# Leave as * for local dev
ALLOWED_ORIGINS=["*"]

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Set to true during development for auto-reload
DEBUG=false
